generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum StatType {
  BODY
  MIND
  LIFE
  FREEDOM
  PURPOSE
  FOCO_COINS
  PREMIUM_COINS
  XP
}

enum TransactionSourceType {
  ROUTINE
  ACHIEVEMENT
  PENALTY
  DAILY_BONUS
  SYSTEM
}

enum ExecutionStatus {
  COMPLETED
  SKIPPED
  FAILED
}

// --- MODELS ---

model User {
  id                   String    @id @default(uuid())
  name                 String?
  username             String?   @unique
  email                String    @unique
  password             String?
  phone                String?
  birthDate            DateTime? // birth_date
  gender               String?
  profilePhoto         String?   // profile_photo (Avatar)
  timezone             String?   @default("UTC")
  language             String?   @default("pt-BR")
  country              String?
  city                 String?
  onboardingCompleted  Boolean   @default(false)
  aiPersonality        String?   // Estilo da IA
  aiGoal               String?   // Objetivo principal
  planType             String?   @default("FREE")
  accountStatus        String?   @default("ACTIVE")
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  routines             Routine[]
  tasks                Task[]
  
  // Gamificação e Progresso
  stats                UserStats?
  statTransactions     StatTransaction[]
  taskExecutions       TaskExecution[]
  // Libertesse (Vícios) - A ser descontinuado
  vices                Vice[]
  viceLogs             ViceLog[]
  // Rastreamento Universal (Acompanhe, Libertesse V2, etc)
  trackerItems         TrackerItem[]
  trackerLogs          TrackerLog[]
}

model UserStats {
  id               String   @id @default(uuid())

  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Atributos de Evolução
  body             Int      @default(0)
  mind             Int      @default(0)
  life             Int      @default(0)
  freedom          Int      @default(0)
  purpose          Int      @default(0)

  // Economia
  focoCoins        Int      @default(0)
  premiumCoins     Int      @default(0)

  // Progressão
  level            Int      @default(1)
  xp               Int      @default(0)

  // Consistência
  streakDays       Int      @default(0)

  // Mascot State (Mochila, Humor, Vitais)
  plocState        Json?
  lastPlocSync     DateTime?

  lastCalculatedAt DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model StatTransaction {
  id            String   @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  statType      StatType

  amount        Int

  sourceType    TransactionSourceType

  sourceId      String?

  description   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([statType])
  @@index([sourceType])
}

model Routine {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // TREINO, ESTUDO, TRABALHO, etc
  description String?
  config      Json?    // Estrutura para dias da semana, horários, etc (ex: { "days": [1,3,5], "time": "08:00" })
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Gamificação e Execução
  rewards     RoutineReward[]
  executions  TaskExecution[]

  @@index([userId])
}

model RoutineReward {
  id          String    @id @default(uuid())

  routineId   Int
  routine     Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)

  statType    StatType

  amount      Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([routineId])
}

model TaskExecution {
  id                String            @id @default(uuid())

  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  routineId         Int
  routine           Routine           @relation(fields: [routineId], references: [id], onDelete: Cascade)

  status            ExecutionStatus

  startedAt         DateTime?
  finishedAt        DateTime?

  completedOnTime   Boolean           @default(false)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([routineId])
  @@index([status])
}

model RoutineTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  description String?
  config      Json     // Configuração padrão sugerida
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Task {
  id            Int        @id @default(autoincrement())
  name          String
  description   String?    // Detalhes da tarefa
  category      String     // Saude, Financias, Trabalho, etc.
  priority      Priority   @default(MEDIA)
  status        TaskStatus @default(PENDENTE)
  tags          String?    // Tags separadas por vírgula
  completed     Boolean    @default(false)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId     Int?
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  scheduledDate DateTime   @default(now())
  scheduledTime String?    // Horário (ex: "08:00"). Se nulo, é dia inteiro.
  completedAt   DateTime?
  color         String?    // Cor opcional da tarefa (ex: "text-rose-400 bg-rose-500/10")
  isDraggable   Boolean    @default(true) // Se a tarefa pode ser arrastada no calendário

  @@index([userId])
  @@index([routineId])
  @@index([completed])
  @@index([status])
  @@index([priority])
}

// --- LIBERTESSE (Vices) ---

model Vice {
  id                        String    @id @default(uuid())
  viceId                    String    // Identificador base (ex: 'smoking', 'social_media')
  customName                String?   // Nome customizado se houver
  mode                      String    // 'acompanhe', 'diminua', 'pare'
  startTime                 BigInt    // timestamp (ms) do inicio do ciclo atual
  expectedFrequency         String?   // Para modo acompanhe
  timerLimitSeconds         Int?      // Limite do timer (diminua/pare)
  reductionTarget           Int?      // Meta de redução (diminua)
  
  // Consumo ativo
  isConsuming               Boolean   @default(false)
  consumptionStartTime      BigInt?   // timestamp
  defaultConsumptionSeconds Int       @default(300)
  costPerUse                Float?    // Custo por consumo
  currentMotivator          String?   // Motivador atual

  userId                    String
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  logs                      ViceLog[]

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([userId])
  @@index([viceId])
  @@unique([userId, viceId])
}

model ViceLog {
  id                String   @id @default(uuid())
  type              String   // 'consumption', 'expense', 'start', 'end'
  timestamp         BigInt   // timestamp do evento
  durationSeconds   Int?
  fastingSeconds    Int?
  cost              Float?
  motivator         String?

  viceId            String
  vice              Vice     @relation(fields: [viceId], references: [id], onDelete: Cascade)

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@index([viceId])
  @@index([userId])
  @@index([type])
}

// --- RASTREAMENTO UNIVERSAL (Acompanhe, Vícios, Hábitos) ---

model TrackerItem {
  id               String   @id @default(uuid())
  type             String   // 'medicine', 'vice', 'habit', 'savings', etc
  name             String   // Nome da tarefa/item
  description      String?  // Propósito/Finalidade
  status           String   @default("ACTIVE") // 'ACTIVE', 'PAUSED', 'COMPLETED'
  coverPhoto       String?  // URL da foto no MinIO

  // Configurações e Condições (Flexible JSON)
  // Ex: { "conditions": ["Jejum", "Antes de dormir"], "frequency": "daily" }
  config           Json?    @default("{}")

  // Prazos e Tempos
  startDate        DateTime @default(now())
  endDate          DateTime?

  // Relações e Lógicas
  correlations     Json?    @default("{}") // Ex: { "dependsOn": ["id1"], "triggers": ["id2"] }

  // Timers e Controles de Execução em Andamento (Herdados do Libertesse)
  isConsuming      Boolean  @default(false)
  consumptionStart BigInt?
  defaultTimer     Int      @default(300)

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  logs             TrackerLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

model TrackerLog {
  id               String   @id @default(uuid())
  
  trackerItemId    String
  trackerItem      TrackerItem @relation(fields: [trackerItemId], references: [id], onDelete: Cascade)

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             String   // 'consumption', 'expense', 'start', 'end', 'milestone'
  timestamp        BigInt
  
  // Detalhes flexíveis de Log
  photoUrl         String?  // Foto tirada na hora do log (MinIO)
  info             String?  // Observações livres ou motivadores
  durationSeconds  Int?     // Tempo de duração da execução
  value            Float?   // Custo (dinheiro) ou outra métrica
  metadata         Json?    @default("{}") // Qualquer dado extra do log

  createdAt        DateTime @default(now())

  @@index([trackerItemId])
  @@index([userId])
  @@index([type])
}
