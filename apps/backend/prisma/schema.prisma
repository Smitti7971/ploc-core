generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum StatType {
  BODY
  MIND
  LIFE
  FREEDOM
  PURPOSE
  FOCO_COINS
  PREMIUM_COINS
  XP
}

enum TransactionSourceType {
  ROUTINE
  ACHIEVEMENT
  PENALTY
  DAILY_BONUS
  SYSTEM
}

enum ExecutionStatus {
  COMPLETED
  SKIPPED
  FAILED
}

// --- MODELS ---

model User {
  id                   String    @id @default(uuid())
  name                 String?
  username             String?   @unique
  email                String    @unique
  password             String?
  phone                String?
  birthDate            DateTime? // birth_date
  gender               String?
  profilePhoto         String?   // profile_photo (Avatar)
  timezone             String?   @default("UTC")
  language             String?   @default("pt-BR")
  country              String?
  city                 String?
  onboardingCompleted  Boolean   @default(false)
  aiPersonality        String?   // Estilo da IA
  aiGoal               String?   // Objetivo principal
  planType             String?   @default("FREE")
  accountStatus        String?   @default("ACTIVE")
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  // Rastreamento Universal (Acompanhe, Libertesse V2, etc)
  trackerItems         TrackerItem[]
  trackerLogs          TrackerLog[]

  // Gamificação e Progresso
  stats                UserStats?
  statTransactions     StatTransaction[]
  // Mochila (Inventário)
  inventory            UserInventory[]

  // Perfil Corporal e Evolução (Fitness Coach)
  fitnessProfile       UserFitnessProfile?
  dailyCheckins        DailyCheckin[]
  
  // Treinos
  workoutPlans         WorkoutPlan[]
  exerciseSessionLogs  ExerciseSessionLog[]
}

model UserStats {
  id               String   @id @default(uuid())

  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Atributos de Evolução
  body             Int      @default(0)
  mind             Int      @default(0)
  life             Int      @default(0)
  freedom          Int      @default(0)
  purpose          Int      @default(0)

  // Economia
  focoCoins        Int      @default(0)
  premiumCoins     Int      @default(0)

  // Progressão
  level            Int      @default(1)
  xp               Int      @default(0)

  // Consistência
  streakDays       Int      @default(0)

  // Mascot State (Mochila, Humor, Vitais)
  plocState        Json?
  lastPlocSync     DateTime?

  lastCalculatedAt DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model StatTransaction {
  id            String   @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  statType      StatType

  amount        Int

  sourceType    TransactionSourceType

  sourceId      String?

  description   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([statType])
  @@index([sourceType])
}



// --- RASTREAMENTO UNIVERSAL (Acompanhe, Vícios, Hábitos) ---

model TrackerItem {
  id               String   @id @default(uuid())
  type             String   // 'medicine', 'vice', 'habit', 'savings', etc
  name             String   // Nome da tarefa/item
  description      String?  // Propósito/Finalidade
  status           String   @default("ACTIVE") // 'ACTIVE', 'PAUSED', 'COMPLETED'
  coverPhoto       String?  // URL da foto no MinIO

  // Configurações e Condições (Flexible JSON)
  // Ex: { "conditions": ["Jejum", "Antes de dormir"], "frequency": "daily" }
  config           Json?    @default("{}")

  // Prazos e Tempos
  startDate        DateTime @default(now())
  endDate          DateTime?

  // Relações e Lógicas
  correlations     Json?    @default("{}") // Ex: { "dependsOn": ["id1"], "triggers": ["id2"] }

  // Timers e Controles de Execução em Andamento (Herdados do Libertesse)
  isConsuming      Boolean  @default(false)
  consumptionStart BigInt?
  defaultTimer     Int      @default(300)

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  logs             TrackerLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

model TrackerLog {
  id               String   @id @default(uuid())
  
  trackerItemId    String
  trackerItem      TrackerItem @relation(fields: [trackerItemId], references: [id], onDelete: Cascade)

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             String   // 'consumption', 'expense', 'start', 'end', 'milestone'
  timestamp        BigInt
  
  // Detalhes flexíveis de Log
  photoUrl         String?  // Foto tirada na hora do log (MinIO)
  info             String?  // Observações livres ou motivadores
  durationSeconds  Int?     // Tempo de duração da execução
  value            Float?   // Custo (dinheiro) ou outra métrica
  metadata         Json?    @default("{}") // Qualquer dado extra do log

  createdAt        DateTime @default(now())

  @@index([trackerItemId])
  @@index([userId])
  @@index([type])
}

// --- MOCHILA (Inventory) ---

model InventoryItem {
  id               String   @id @default(uuid())
  slug             String   @unique // ex: 'foco-potion', 'coffee'
  name             String
  description      String?
  type             String   // 'CONSUMABLE', 'EQUIPPABLE', 'COLLECTIBLE'
  rarity           String   @default("COMMON") // 'COMMON', 'UNCOMMON', 'RARE', 'EPIC', 'LEGENDARY'
  priceFoco        Int?     // Preço em Foco Coins
  pricePremium     Int?     // Preço em Premium Coins
  effects          Json?    // Efeitos ao usar: { "body": 5, "duration_minutes": 30 }
  imageUrl         String?
  isAvailableInShop Boolean @default(true)

  users            UserInventory[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserInventory {
  id               String   @id @default(uuid())

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  inventoryItemId  String
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  quantity         Int      @default(1)
  isEquipped       Boolean  @default(false)
  acquiredAt       DateTime @default(now())

  @@unique([userId, inventoryItemId]) // Garante que não haja linhas duplicadas pro mesmo item e usuário
  @@index([userId])
}

// --- FITNESS PROFILE & COACHING ---

model UserFitnessProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Biometria
  gender              String?  // 'masculino', 'feminino', 'outro'
  age                 Int?
  weight              Float?   // kg
  height              Float?   // cm
  targetWeight        Float?   // kg
  bodyFatPercentage   Float?
  muscleMass          Float?
  leanMass            Float?
  
  // Medidas Corporais (Chest, Waist, Hips, Arms, etc)
  measurements        Json?    @default("{}")

  // Objetivos e Nível
  primaryObjective    String?  // 'emagrecer', 'hipertrofia', 'saude', 'forca'
  experienceLevel     String?  // 'iniciante', 'intermediario', 'avancado'
  
  // Preferências
  desiredFrequency    Int?     // Dias por semana
  availableTime       Int?     // Minutos
  trainingLocation    String?  // 'academia', 'casa'
  
  // JSONs Dinâmicos (Para listas)
  secondaryObjectives Json?    @default("[]")
  availableEquipment  Json?    @default("[]")
  injuries            Json?    @default("[]")
  forbiddenExercises  Json?    @default("[]")
  medicalRestrictions Json?    @default("[]")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DailyCheckin {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             DateTime @default(now()) // Data do check-in
  
  // Avaliação 1 a 5
  energy           Int
  sleepQuality     Int
  mood             Int
  stressLevel      Int
  musclePain       Int
  readinessToTrain Int

  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([date])
}

// --- BANCO DE DADOS DE EXERCÍCIOS E EQUIPAMENTOS ---

model Equipment {
  id               String   @id @default(uuid())
  slug             String   @unique // ex: 'banco-reto', 'halteres'
  name             String
  image            String?
  isCustom         Boolean  @default(false)
  userId           String?  // Nulo se for equipamento padrão/global do app
  deletedAt        DateTime? 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model ExerciseDefinition {
  id               String   @id @default(uuid())
  name             String
  muscleGroups     Json     // ex: ["chest", "triceps"]
  requiredEquipment Json    // Array de Slugs de equipamentos
  image            String?
  imageType        String?  @default("url")
  isCustom         Boolean  @default(false)
  userId           String?  // Nulo se for exercício global
  deletedAt        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([userId])
}

// --- PLANEJAMENTO DE TREINOS ---

model WorkoutPlan {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name             String   // ex: "HIPERTROFIA ACADEMIA PARA AVANÇADO"
  isActive         Boolean  @default(true)
  
  // Guardamos a configuração completa gerada (exercícios, dias, divisões) 
  // no formato JSON para flexibilidade da Timeline do frontend.
  exercisesData    Json     
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

// --- HISTÓRICO DE ACOMPANHAMENTO (LOGS DE TREINO) ---

model ExerciseSessionLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workoutPlanId    String?  // Referência ao plano atual (se houver)
  exerciseName     String   // Nome do exercício feito
  
  setsData         Json     // Array detalhado: [{ weight: "20kg", reps: 10, completed: true }]
  comment          String?  // Observações

  timestamp        BigInt   // Data e hora exata
  
  createdAt        DateTime @default(now())

  @@index([userId])
}
