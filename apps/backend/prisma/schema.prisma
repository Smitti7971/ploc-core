generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model User {
  id                   String    @id @default(uuid())
  name                 String?
  username             String?   @unique
  email                String    @unique
  password             String?
  phone                String?
  birthDate            DateTime? // birth_date
  gender               String?
  profilePhoto         String?   // profile_photo (Avatar)
  timezone             String?   @default("UTC")
  language             String?   @default("pt-BR")
  country              String?
  city                 String?
  onboardingCompleted  Boolean   @default(false)
  aiPersonality        String?   // Estilo da IA
  aiGoal               String?   // Objetivo principal
  planType             String?   @default("FREE")
  accountStatus        String?   @default("ACTIVE")
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  routines             Routine[]
  tasks                Task[]
  plants               Plant[]
}

model Routine {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // TREINO, ESTUDO, TRABALHO, etc
  description String?
  config      Json?    // Estrutura para dias da semana, horários, etc
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model RoutineTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  description String?
  config      Json     // Configuração padrão sugerida
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Task {
  id            Int        @id @default(autoincrement())
  name          String
  description   String?    // Detalhes da tarefa
  category      String     // Saude, Financias, Trabalho, etc.
  priority      Priority   @default(MEDIA)
  status        TaskStatus @default(PENDENTE)
  tags          String?    // Tags separadas por vírgula
  completed     Boolean    @default(false)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId     Int?
  routine       Routine?   @relation(fields: [routineId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  scheduledDate DateTime   @default(now())
  scheduledTime String?    // Horário (ex: "08:00")
  completedAt   DateTime?

  @@index([userId])
  @@index([routineId])
  @@index([completed])
  @@index([status])
  @@index([priority])
}

// --- SISTEMA DE PLANTAS (PRO) ---

model Plant {
  id            String    @id @default(uuid())
  name          String
  species       String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  germinatedAt  DateTime? // TIMESTAMPTZ
  harvestedAt   DateTime? // TIMESTAMPTZ
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  phases        PlantPhase[]
  logs          PlantLog[]
  events        PlantEvent[]
  media         PlantMedia[]

  @@index([userId])
  @@index([createdAt])
}

model PlantPhase {
  id          String    @id @default(uuid())
  plantId     String
  plant       Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  
  phaseName   String    // ex: "Germinação", "Vegetativo", "Floração"
  startedAt   DateTime  // TIMESTAMPTZ
  endedAt     DateTime? // TIMESTAMPTZ

  createdAt   DateTime  @default(now())

  @@index([plantId])
  @@index([startedAt])
}

model PlantLog {
  id          String    @id @default(uuid())
  plantId     String
  plant       Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  
  title       String
  mood        String    @default("healthy") // healthy, stressed, warning, etc
  notes       String?
  tags        Json?     // JSONB: ["rega", "poda", etc]
  
  loggedAt    DateTime  @default(now()) // Referência principal para Calendário

  media       PlantMedia[]
  
  createdAt   DateTime  @default(now())

  @@index([plantId])
  @@index([loggedAt])
}

model PlantMedia {
  id          String    @id @default(uuid())
  plantId     String
  plant       Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  
  logId       String?
  log         PlantLog? @relation(fields: [logId], references: [id], onDelete: SetNull)
  
  url         String    // media_url
  type        String    @default("image") // image, video, timelapse, ai-generated
  fileSize    Int?      // file_size
  metadata    Json?     // JSONB: { camera: "iphone", ai_analysis: { ... } }
  
  createdAt   DateTime  @default(now())

  @@index([plantId])
  @@index([logId])
}

model PlantEvent {
  id          String    @id @default(uuid())
  plantId     String
  plant       Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  
  type        String    // watering, fertilization, pruning, harvest, etc
  title       String
  description String?
  
  startsAt    DateTime  // TIMESTAMPTZ
  endsAt      DateTime? // TIMESTAMPTZ
  
  status      String    @default("pending") // pending, completed, skipped
  metadata    Json?     // JSONB
  
  createdAt   DateTime  @default(now())

  @@index([plantId])
  @@index([startsAt])
  @@index([type])
}
